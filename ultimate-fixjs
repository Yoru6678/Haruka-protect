const server = http.createServer((req, res) => {
    res.writeHead(200, { 'Content-Type': 'text/plain' });
    res.end('🛡️ Haruka Protect - Bot en ligne');
});

const PORT = process.env.PORT || 8000;
server.listen(PORT, () => {
