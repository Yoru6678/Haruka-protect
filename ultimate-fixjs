    console.log(\`🛡️  \${client.commands.size} commandes chargées\`);
    console.log(\`🛡️  Haruka Protect est opérationnel!\\\\n\`);
    
    client.user.setActivity('+help | Protection', { type: 3 }); // WATCHING
});

