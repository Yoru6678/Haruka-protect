// === 5. CORRECTION DE TOUS LES FICHIERS JS ===
console.log("\n🔧 Correction de tous les fichiers JavaScript...");

function fixAllJavaScriptFiles() {
    const foldersToFix = ['.', 'commands', 'events', 'antiraid', 'utils', 'moderation', 'parametre', 'gestion', 'utilitaire', 'logs'];
    let totalFixed = 0;

    foldersToFix.forEach(folder => {
        const folderPath = path.join(__dirname, folder);
        if (!fs.existsSync(folderPath)) return;

        const files = fs.readdirSync(folderPath);
        files.forEach(file => {
            if (file.endsWith('.js')) {
                const filePath = path.join(folderPath, file);
                try {
                    let content = fs.readFileSync(filePath, 'utf8');
                    
                    // Corrections globales
                    let fixedContent = content
                        // Correction de l'encodage HTML
                        .replace(/&amp;gt;/g, ">")
                        .replace(/&amp;lt;/g, "<")
                        .replace(/&amp;amp;/g, "&")
                        // Correction des méthodes deprecated
                        .replace(/\.members\.get\(/g, ".members.fetch(")
                        .replace(/client\.channels\.cache\.get\((.*?)\)\s*send\(/g, (m, p1) => {
                            return `const chan = client.channels.cache.get(${p1});\nif (chan) chan.send(`;
                        })
                        // Correction des imports Discord.js
                        .replace(/require\("discord.js"\)/g, `require("discord.js").default || require("discord.js")`)
                        // Correction des embeds
                        .replace(/new Discord\.MessageEmbed\(\)/g, `new (require("discord.js").EmbedBuilder)()`)
                        .replace(/MessageEmbed/g, "EmbedBuilder")
                        .replace(/MessageActionRow/g, "ActionRowBuilder")
                        .replace(/MessageButton/g, "ButtonBuilder")
                        .replace(/MessageSelectMenu/g, "StringSelectMenuBuilder")
                        // Correction des permissions
                        .replace(/Permissions\.FLAGS/g, "PermissionsBitField.Flags")
                        .replace(/MANAGE_CHANNELS/g, "ManageChannels")
                        .replace(/MANAGE_ROLES/g, "ManageRoles")
                        .replace(/ADMINISTRATOR/g, "Administrator")
                        .replace(/MODERATE_MEMBERS/g, "ModerateMembers")
                        .replace(/SEND_MESSAGES/g, "SendMessages")
                        .replace(/VIEW_CHANNEL/g, "ViewChannel")
                        // Correction des types de channel
                        .replace(/GUILD_TEXT/g, "GuildText")
                        .replace(/GUILD_CATEGORY/g, "Category")
                        // Correction des styles de boutons
                        .replace(/PRIMARY/g, "Primary")
                        .replace(/DANGER/g, "Danger")
                        .replace(/SUCCESS/g, "Success")
                        // Correction des fonctions asynchrones
                        .replace(/module\.exports = {/, `module.exports = {`)
                        .replace(/async execute\(client, message, args\)/, `async execute(message, args)`)
                        // Ajout du client si nécessaire
                        .replace(/async execute\(message, args\)/, `async execute(message, args)`)
                        // Correction des collectors
                        .replace(/createMessageComponentCollector\({[\s\S]*?componentType: "BUTTON"/g, `createMessageComponentCollector({\n                    componentType: ComponentType.Button`)
                        .replace(/componentType: "SELECT_MENU"/g, `componentType: ComponentType.StringSelect`);

                    if (fixedContent !== content) {
                        fs.writeFileSync(filePath, fixedContent, 'utf8');
                        console.log(`✅ Corrigé: ${folder}/${file}`);
                        totalFixed++;
                    }
                } catch (error) {
                    console.log(`⚠️  Impossible de corriger: ${folder}/${file}`);
                }
            }
        });
    });
    return totalFixed;
}

